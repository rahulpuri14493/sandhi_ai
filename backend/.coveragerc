[run]
source = .
relative_files = true
omit =
    */migrations/*
    alembic/*
    fix_user_passwords.py
    run.py
    run_celery_worker.py
    services/task_queue.py
    venv/*
    .venv/*
    tests/**
    */tests/**

[paths]
source =
    .
    /app
    */backend
    D:\sandhi_ai\backend
    d:\sandhi_ai\backend

[report]
omit =
    tests/**
    */tests/**
    run_celery_worker.py
    services/task_queue.py
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
