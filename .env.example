# ============================================================
# Required variables
# ============================================================
# Required for local Docker stack (backend + db):
# - POSTGRES_USER
# - POSTGRES_PASSWORD
# - POSTGRES_DB
# - SECRET_KEY
# - MCP_INTERNAL_SECRET
#
# Required only when using S3/MinIO storage overlay:
# - S3_ACCESS_KEY_ID
# - S3_SECRET_ACCESS_KEY
# - S3_BUCKET
# ============================================================

# Database (used by Docker Compose and backend) [REQUIRED]
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=agent_marketplace

# Backend [REQUIRED]
SECRET_KEY=your-secret-key-change-in-production
# Optional: JWT
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# MCP: Encryption for stored credentials (connections + tool configs).
# Production: set a long random value (e.g. 32+ chars). If unset, key is derived from SECRET_KEY.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave empty in dev to use SECRET_KEY-derived key; set in production for independent credential encryption.
MCP_ENCRYPTION_KEY=

# MCP: Platform MCP server (tool discovery + invocation for agents). [REQUIRED]
# Set same secret in backend and platform-mcp-server.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_INTERNAL_SECRET=
# Optional: URL of platform MCP server (default in backend: http://platform-mcp-server:8081)
# PLATFORM_MCP_SERVER_URL=http://platform-mcp-server:8081

# Optional: A2A adapter (platform service). In Docker Compose this is the service name; if the backend
# runs on the host while the adapter is in Docker, use the published port, e.g. http://localhost:8080
# A2A_ADAPTER_URL=http://a2a-openai-adapter:8080

# Validate executor→agent JSON (types) and attach sandhi_trace for every step. Default true (recommended for production).
# EXECUTOR_PAYLOAD_VALIDATE=true

# A2A outbound pre-flight before agent HTTP: JSON serialization + size (defaults on). See docs/A2A_TASK_AND_ASSIGNMENT.md
# A2A_OUTBOUND_VALIDATE=true
# A2A_OUTBOUND_MAX_BYTES=4194304
# Require sandhi_a2a_task on every outbound call (default true). Set false only for legacy agents without the envelope.
# A2A_TASK_ENVELOPE_STRICT=true

# Tool assignment (registry + optional LLM). See docs/A2A_TASK_AND_ASSIGNMENT.md
#
# TOOL_ASSIGNMENT_REGISTRY_PATH — absolute path to a JSON registry file that maps task_type →
# preferred MCP tool_type values and max_tools per step. If empty/unset, the backend uses the
# packaged default: backend/resources/config/tool_assignment_registry.default.json
# Examples:
#   Linux/macOS: TOOL_ASSIGNMENT_REGISTRY_PATH=/etc/sandhi/tool_assignment_registry.json
#   Windows:     TOOL_ASSIGNMENT_REGISTRY_PATH=D:\config\sandhi\tool_assignment_registry.json
#   Docker: mount your file and point the container at it, e.g.
#     volumes: ["./my-registry.json:/config/tool_assignment_registry.json:ro"]
#     env: TOOL_ASSIGNMENT_REGISTRY_PATH=/config/tool_assignment_registry.json
# After changing the file on disk, reload without redeploy (requires EXTERNAL_API_KEY):
#   curl -X POST -H "X-API-Key: $EXTERNAL_API_KEY" \
#     http://localhost:8000/api/external/platform/tool-assignment-registry/reload
# TOOL_ASSIGNMENT_REGISTRY_PATH=
#
# TOOL_ASSIGNMENT_ENABLED — when true (default), each step uses the registry: infer task_type
# from step input_data (explicit task_type slug from workflow UI, or heuristic from assigned_task),
# pick tools whose tool_type matches the rule, cap count, set sandhi_a2a_task.assignment_source /
# assignment_flagged. When false, the engine is bypassed: all visible MCP tools are passed through
# in discovery order (assignment_source=passthrough) — useful to debug agents or compare behavior.
# TOOL_ASSIGNMENT_ENABLED=true
# Reorder assigned tools using llm_suggested_tool_names on step input when present (default true).
# TOOL_ASSIGNMENT_USE_LLM=true
# With USE_LLM + AGENT_PLANNER_API_KEY: at step execution, planner may pick tool names from the allowlist (default true; no-op if no key or no tools).
# TOOL_ASSIGNMENT_LLM_PICK_TOOLS=true
# TOOL_ASSIGNMENT_LLM_MAX_TOOLS=12

# Workflow: run consecutive steps with depends_on_previous=false in parallel (separate DB sessions; cap concurrency).
# WORKFLOW_PARALLEL_INDEPENDENT_STEPS=true
# WORKFLOW_MAX_PARALLEL_STEPS=8
# Step guardrails (applies to sequential + async branches): hard timeout + bounded retries + output quality gate.
# AGENT_STEP_TIMEOUT_SECONDS=180
# AGENT_STEP_MAX_RETRIES=2
# AGENT_STEP_RETRY_BACKOFF_SECONDS=2
# AGENT_OUTPUT_REQUIRE_NONEMPTY=true
# AGENT_OUTPUT_MIN_CONFIDENCE=0.0

# ------------------------------------------------------------
# Alerts Quick Start (Heartbeat + KPI/SLA)
# Copy, uncomment, and set your webhook URLs.
# Full guide: docs/HEARTBEAT_AND_KPI_GUIDE.md
# ------------------------------------------------------------

# Heartbeat runtime telemetry (Redis hot state + DB durable snapshot)
# HEARTBEAT_ENABLE_REDIS=true
# HEARTBEAT_REDIS_URL=redis://redis:6379/0
# HEARTBEAT_REDIS_TTL_SECONDS=180
# HEARTBEAT_ENABLE_DB_SNAPSHOT=true
# HEARTBEAT_DB_MIN_UPDATE_SECONDS=45
# STEP_STUCK_THRESHOLD_SECONDS=600
# STEP_STUCK_BLOCKED_THRESHOLD_SECONDS=900

# Business job lifecycle webhook (started/stuck/failed/completed)
# BUSINESS_JOB_ALERTS_ENABLED=true
# BUSINESS_JOB_ALERT_WEBHOOK_URL=https://example.com/webhooks/business-jobs
# BUSINESS_JOB_ALERT_COOLDOWN_SECONDS=180

# Business KPI/SLA webhook (at_risk/breached + recovered to healthy)
# BUSINESS_KPI_ALERTS_ENABLED=true
# BUSINESS_KPI_ALERT_WEBHOOK_URL=https://example.com/webhooks/business-kpi
# BUSINESS_KPI_ALERT_COOLDOWN_SECONDS=900
# BUSINESS_KPI_SLA_SUCCESS_RATE_MIN=0.95
# BUSINESS_KPI_SLA_P95_LATENCY_SECONDS_MAX=45.0

# Developer KPI/SLA webhook (at_risk/breached + recovered to healthy)
# DEVELOPER_KPI_ALERTS_ENABLED=true
# DEVELOPER_KPI_ALERT_WEBHOOK_URL=https://example.com/webhooks/developer-kpi
# DEVELOPER_KPI_ALERT_COOLDOWN_SECONDS=900
# DEVELOPER_KPI_SLA_SUCCESS_RATE_MIN=0.95
# DEVELOPER_KPI_SLA_P95_LATENCY_SECONDS_MAX=30.0

# Allow agent endpoints that resolve to private/loopback IPs (e.g. localhost, host.docker.internal, Docker service names).
# Set to true for local/Docker development so workflow steps can call agents on the host or same network.
# ALLOW_PRIVATE_AGENT_ENDPOINTS=false

# Optional: External API
# EXTERNAL_API_KEY=
# EXTERNAL_API_BASE_URL=http://localhost:8000

# Storage backend mode (declare in root .env, same folder as docker-compose.yml)
# Default is s3. Set local only if you explicitly want filesystem storage.
# local = store documents on local filesystem
# s3    = store documents in S3-compatible storage (MinIO/Ceph/AWS S3)
OBJECT_STORAGE_BACKEND=s3

# S3 / MinIO credentials [REQUIRED only when OBJECT_STORAGE_BACKEND=s3]
# S3_ACCESS_KEY_ID=sandhi-access-key
# S3_SECRET_ACCESS_KEY=sandhi-secret-key
# S3_BUCKET=sandhi-brd-docs

# Optional: App-level S3 operation retries (on top of botocore retries)
# S3_OPERATION_RETRY_ATTEMPTS=4
# S3_OPERATION_RETRY_BASE_DELAY_SECONDS=0.2
# S3_OPERATION_RETRY_MAX_DELAY_SECONDS=2.0
# S3_OPERATION_RETRY_JITTER_SECONDS=0.1

# Optional: MinIO host port overrides (for local Docker overlay)
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001

# Optional: API rate limits (per client IP, sliding 60s window). Defaults suit ~200 heavy users; raise if many clients share one NAT.
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_AUTH_PER_MINUTE=300
# RATE_LIMIT_AGENT_READS_PER_MINUTE=1200
# RATE_LIMIT_JOB_MUTATIONS_PER_MINUTE=600
# Trust X-Forwarded-For for rate-limit IP (use only behind a trusted reverse proxy):
# RATE_LIMIT_TRUST_PROXY_HEADERS=false

# ------------------------------------------------------------
# Platform Agent Planner (GitHub #62) — optional
# Backend pytest merges the full repo-root .env into the process environment before importing
# the app (shell/CI env vars take precedence). By default pytest forces DATABASE_URL (in-memory
# SQLite), OBJECT_STORAGE_BACKEND=local, and DISABLE_SCHEDULER=true so imports do not hit dev
# Postgres/MinIO. To use your `.env` database URL or S3/MinIO settings instead, set before pytest:
#   PYTEST_USE_DOTENV_DATABASE=1
#   PYTEST_USE_DOTENV_STORAGE=1
#   PYTEST_USE_DOTENV_PLANNER=1
# (values true/yes/on also work.) Do not put these in `.env` — only export in the shell; the test
# harness ignores PYTEST_* keys when merging repo `.env` so accidental file entries cannot opt in.
# API tests still bind routes to the in-memory SQLite session
# fixture unless you change fixtures. Pytest also sets AGENT_PLANNER_ENABLED=false unless
# PYTEST_USE_DOTENV_PLANNER=1 so integration tests do not call your planner model. Other keys
# (cache Redis URL, non-planner API keys, Celery URLs, etc.) still apply.
# When AGENT_PLANNER_API_KEY is set, the platform uses this model for:
# BRD document analysis, auto workflow split, and MCP tool suggestions.
# Workflow Q&A still uses each assigned agent's own endpoint.
# ------------------------------------------------------------
# AGENT_PLANNER_ENABLED=true
# AGENT_PLANNER_PROVIDER=openai_compatible
# AGENT_PLANNER_BASE_URL=https://api.openai.com/v1
# AGENT_PLANNER_API_KEY=
# AGENT_PLANNER_MODEL=gpt-4o-mini
# AGENT_PLANNER_TEMPERATURE=0.3
# AGENT_PLANNER_MAX_TOKENS=4096
# Multi-agent split: retries (no fallback to hired-agent split when planner is configured). Re-fetch BRD from storage between attempts when enabled.
# AGENT_PLANNER_SPLIT_MAX_ATTEMPTS=4
# AGENT_PLANNER_SPLIT_RETRY_BACKOFF_SECONDS=2.0
# AGENT_PLANNER_SPLIT_JSON_REPAIR=true
# AGENT_PLANNER_SPLIT_RELOAD_DOCS_BETWEEN_ATTEMPTS=true
# Re-run planner at job execution start to refresh steps (same agent order / tool columns).
# Skipped when the job's workflow_origin is manual (user-built workflow).
# AGENT_PLANNER_EXECUTE_REPLAN=true
# If replan fails: fail (default) aborts the run; continue runs the workflow as built in the UI.
# AGENT_PLANNER_EXECUTE_REPLAN_ON_FAILURE=fail
# For Anthropic: AGENT_PLANNER_PROVIDER=anthropic and set AGENT_PLANNER_MODEL=claude-3-5-sonnet-20241022 (API key in AGENT_PLANNER_API_KEY)
#
# Planner transport selection is runtime/automatic per job + hired-agent mix.
# Do NOT set install-time planner mode for multi-tenant usage.
#
# Optional transport endpoints used when runtime policy picks that transport:
# native_a2a = JSON-RPC SendMessage to planner A2A endpoint.
# AGENT_PLANNER_A2A_URL=http://your-planner-a2a:8080
# Optional Bearer for platform -> planner A2A hop (model key may stay only on planner service):
# AGENT_PLANNER_A2A_API_KEY=
# a2a_adapter = SendMessage to dedicated planner adapter (never reuse hired-agent A2A_ADAPTER_URL).
# AGENT_PLANNER_ADAPTER_URL=http://a2a-planner-adapter:8080
# (compose maps planner adapter to host port 8082 -> container 8080; from backend container use :8080 service DNS)
#
# Secondary planner failover (alternate upstream API key / model / base URL for quota or credit issues;
# always uses AGENT_PLANNER_A2A_* and AGENT_PLANNER_ADAPTER_URL — no separate secondary adapter):
# AGENT_PLANNER_SECONDARY_ENABLED=true
# AGENT_PLANNER_SECONDARY_PROVIDER=openai_compatible   # empty = inherit primary provider
# AGENT_PLANNER_SECONDARY_BASE_URL=                    # empty = inherit primary base URL
# AGENT_PLANNER_SECONDARY_API_KEY=
# AGENT_PLANNER_SECONDARY_MODEL=                       # empty = inherit primary model
# AGENT_PLANNER_SECONDARY_FALLBACK_MODEL=
# AGENT_PLANNER_SECONDARY_HTTP_TIMEOUT_SECONDS=120
#
# BRD / planner analysis JSON is stored under the same bucket as job uploads: jobs/{job_id}/planner-brd-analysis-*.json
# Postgres table job_planner_artifacts holds pointers (bucket/key or local path). Artifact types include brd_analysis, task_split, tool_suggestion.
# Optional read-through Redis cache for GET /api/jobs/{id}/planner-artifacts/{id}/raw (empty = disabled; use a dedicated Redis DB, not Celery broker):
# PLANNER_ARTIFACT_CACHE_REDIS_URL=
# PLANNER_ARTIFACT_CACHE_TTL_SECONDS=300