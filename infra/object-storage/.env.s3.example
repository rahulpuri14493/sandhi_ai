# ============================================================
# S3 / Object Storage environment variables
# ============================================================
# Copy these into your root .env file.
#
# Option A — Docker Compose (dev / single-box):
#   docker compose -f docker-compose.yml -f docker-compose.s3.yml up -d
#   Uses MinIO as a lightweight S3-compatible store.
#   Only S3_ACCESS_KEY_ID and S3_SECRET_ACCESS_KEY are required.
#
# Option B — External S3 endpoint (production):
#   Point to AWS S3, Ceph RGW, or any S3-compatible service.
#   Set S3_ENDPOINT_URL below and skip docker-compose.s3.yml.
# ============================================================

# --- Required: S3 credentials (both options) ---
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=sandhi-brd-docs

# --- Option B only: point backend to external S3 ---
# OBJECT_STORAGE_BACKEND=s3
# S3_ENDPOINT_URL=https://s3.example.com
# S3_REGION=us-east-1
# S3_ADDRESSING_STYLE=path

# --- Optional: MinIO ports (Option A, defaults shown) ---
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001

# --- Optional: S3 client tuning ---
# S3_SIGNATURE_VERSION=s3v4
# S3_TCP_KEEPALIVE=true
# S3_CONNECT_TIMEOUT_SECONDS=5
# S3_READ_TIMEOUT_SECONDS=60
# S3_MAX_POOL_CONNECTIONS=100
# S3_MAX_ATTEMPTS=5
# S3_RETRY_MODE=standard
# S3_OPERATION_RETRY_ATTEMPTS=4
# S3_OPERATION_RETRY_BASE_DELAY_SECONDS=0.2
# S3_OPERATION_RETRY_MAX_DELAY_SECONDS=2.0
# S3_OPERATION_RETRY_JITTER_SECONDS=0.1
