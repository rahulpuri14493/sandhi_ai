# ============================================================
# Ceph / S3 environment variables
# ============================================================
# Copy these into your root .env file.
#
# Option A — External Ceph cluster (recommended for HA production):
#   Set the S3 variables below and skip docker-compose.ceph.yml entirely.
#
# Option B — Docker Compose single-box cluster:
#   docker compose -f docker-compose.yml -f docker-compose.ceph.yml up -d
#   Only S3_ACCESS_KEY_ID and S3_SECRET_ACCESS_KEY are required.
#   The cluster auto-generates FSID, keyrings, and config on first boot.
# ============================================================

# --- Required: S3 credentials (both options) ---
S3_ACCESS_KEY_ID=<your-access-key>
S3_SECRET_ACCESS_KEY=<your-secret-key>
S3_BUCKET=sandhi-brd-docs

# --- Option A only: point backend to external RGW ---
# OBJECT_STORAGE_BACKEND=s3
# S3_ENDPOINT_URL=https://rgw.example.com
# S3_REGION=us-east-1
# S3_ADDRESSING_STYLE=path

# --- Optional: RGW port (both options, default 7480) ---
# CEPH_RGW_PORT=7480

# --- Optional: S3 client tuning ---
# S3_SIGNATURE_VERSION=s3v4
# S3_TCP_KEEPALIVE=true
# S3_CONNECT_TIMEOUT_SECONDS=5
# S3_READ_TIMEOUT_SECONDS=60
# S3_MAX_POOL_CONNECTIONS=100
# S3_MAX_ATTEMPTS=5
# S3_RETRY_MODE=standard
